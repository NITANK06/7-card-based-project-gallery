<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Project Gallery</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <section class="gallery">
    <h1>My Projects</h1>
    <div class="card-container">
      <div class="card">
        <img src="images/project1.jpg" alt="Project 1">
        <h2>Project One</h2>
        <p>A brief description of project one.</p>
      </div>
      <div class="card">
        <img src="images/project2.jpg" alt="Project 2">
        <h2>Project Two</h2>
        <p>A brief description of project two.</p>
      </div>
      <div class="card">
        <img src="images/project3.jpg" alt="Project 3">
        <h2>Project Three</h2>
        <p>A brief description of project three.</p>
      </div>
      <div class="card">
        <img src="images/project4.jpg" alt="Project 4">
        <h2>Project Four</h2>
        <p>A brief description of project four.</p>
      </div>
      <div class="card">
        <img src="images/project5.jpg" alt="Project 5">
        <h2>Project Five</h2>
        <p>A brief description of project five.</p>
      </div>
      <div class="card">
        <img src="images/project6.jpg" alt="Project 6">
        <h2>Project Six</h2>
        <p>A brief description of project six.</p>
      </div>
    </div>
  </section>
</body>
</html>
